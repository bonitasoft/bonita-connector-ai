  <process:MainProcess xmi:id="_AiDemoMp01" name="AnthropicAIDemo" bonitaModelVersion="9">
    <elements xmi:type="process:Pool" xmi:id="_AiDemoPool01" name="Anthropic AI Demo">
      <elements xmi:type="process:Lane" xmi:id="_AiDemoLane01" name="Employee lane" actor="_AiDemoActor01">
        <elements xmi:type="process:StartEvent" xmi:id="_AiDemoStart01" name="Start" outgoing="_AiDemoFlow01">
          <dynamicLabel xmi:type="expression:Expression" xmi:id="_AiDemoStart01dl" name="" content="" returnTypeFixed="true"/>
          <dynamicDescription xmi:type="expression:Expression" xmi:id="_AiDemoStart01dd" name="" content="" returnTypeFixed="true"/>
          <stepSummary xmi:type="expression:Expression" xmi:id="_AiDemoStart01ss" name="" content="" returnTypeFixed="true"/>
        </elements>
        <elements xmi:type="process:ServiceTask" xmi:id="_AiDemoTaskAsk01" name="Ask Claude" incoming="_AiDemoFlow01" outgoing="_AiDemoFlow02">
          <dynamicLabel xmi:type="expression:Expression" xmi:id="_AiDemoTaskAsk01dl" name="" content="" returnTypeFixed="true"/>
          <dynamicDescription xmi:type="expression:Expression" xmi:id="_AiDemoTaskAsk01dd" name="" content="" returnTypeFixed="true"/>
          <stepSummary xmi:type="expression:Expression" xmi:id="_AiDemoTaskAsk01ss" name="" content="" returnTypeFixed="true"/>
          <connectors xmi:type="process:Connector" xmi:id="_AiDemoConn01" name="Anthropic Ask" definitionId="anthropic-ask" event="ON_ENTER" definitionVersion="1.0.0">
            <configuration xmi:type="connectorconfiguration:ConnectorConfiguration" xmi:id="_AiDemoConf01" definitionId="anthropic-ask" version="1.0.0" modelVersion="9">
              <parameters xmi:type="connectorconfiguration:ConnectorParameter" xmi:id="_AiDemoConfP01" key="userPrompt">
                <expression xmi:type="expression:Expression" xmi:id="_AiDemoConfE01" name="userPrompt" content="What is the capital of France? Answer with just the city name." type="TYPE_CONSTANT" returnType="java.lang.String"/>
              </parameters>
              <parameters xmi:type="connectorconfiguration:ConnectorParameter" xmi:id="_AiDemoConfP02" key="systemPrompt">
                <expression xmi:type="expression:Expression" xmi:id="_AiDemoConfE02" name="systemPrompt" content="You are a helpful assistant." type="TYPE_CONSTANT" returnType="java.lang.String"/>
              </parameters>
            </configuration>
            <outputs xmi:type="expression:Operation" xmi:id="_AiDemoOut01">
              <leftOperand xmi:type="expression:Expression" xmi:id="_AiDemoOutL01" name="askResult" content="askResult" type="TYPE_VARIABLE" returnType="java.lang.String">
                <referencedElements xmi:type="process:Data" xmi:id="_AiDemoOutLR01" name="askResult" dataType="_AiDemoStringType"/>
              </leftOperand>
              <rightOperand xmi:type="expression:Expression" xmi:id="_AiDemoOutR01" name="output" content="output" type="CONNECTOR_OUTPUT_TYPE" returnType="java.lang.String">
                <referencedElements xmi:type="definition:Output" xmi:id="_AiDemoOutRR01" name="output" type="java.lang.String"/>
              </rightOperand>
              <operator xmi:type="expression:Operator" xmi:id="_AiDemoOutOp01" type="ASSIGNMENT"/>
            </outputs>
          </connectors>
          <loopCondition xmi:type="expression:Expression" xmi:id="_AiDemoTaskAsk01lc" name="" content="" returnType="java.lang.Boolean" returnTypeFixed="true"/>
          <loopMaximum xmi:type="expression:Expression" xmi:id="_AiDemoTaskAsk01lm" name="" content="" returnType="java.lang.Integer" returnTypeFixed="true"/>
          <cardinalityExpression xmi:type="expression:Expression" xmi:id="_AiDemoTaskAsk01ce" name="" content="" returnType="java.lang.Integer" returnTypeFixed="true"/>
          <iteratorExpression xmi:type="expression:Expression" xmi:id="_AiDemoTaskAsk01ie" name="multiInstanceIterator" content="multiInstanceIterator" type="MULTIINSTANCE_ITERATOR_TYPE" returnType="java.lang.Object" returnTypeFixed="true"/>
          <completionCondition xmi:type="expression:Expression" xmi:id="_AiDemoTaskAsk01cc" name="" content="" returnType="java.lang.Boolean" returnTypeFixed="true"/>
        </elements>
        <elements xmi:type="process:Task" xmi:id="_AiDemoTaskRev01" name="Review Results" incoming="_AiDemoFlow02" outgoing="_AiDemoFlow03" overrideActorsOfTheLane="false">
