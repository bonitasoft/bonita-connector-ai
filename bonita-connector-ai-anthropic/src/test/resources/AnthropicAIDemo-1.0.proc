          <contract xmi:type="process:Contract" xmi:id="_AiDemoTaskRev01ct"/>
          <expectedDuration xmi:type="expression:Expression" xmi:id="_AiDemoTaskRev01ed" name="" content="" returnType="java.lang.Long" returnTypeFixed="true"/>
        </elements>
        <elements xmi:type="process:EndEvent" xmi:id="_AiDemoEnd01" name="End" incoming="_AiDemoFlow03">
          <dynamicLabel xmi:type="expression:Expression" xmi:id="_AiDemoEnd01dl" name="" content="" returnTypeFixed="true"/>
          <dynamicDescription xmi:type="expression:Expression" xmi:id="_AiDemoEnd01dd" name="" content="" returnTypeFixed="true"/>
          <stepSummary xmi:type="expression:Expression" xmi:id="_AiDemoEnd01ss" name="" content="" returnTypeFixed="true"/>
        </elements>
