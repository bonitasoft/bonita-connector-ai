          <cardinalityExpression xmi:type="expression:Expression" xmi:id="_AzDemoTaskRev01ce" name="" content="" returnType="java.lang.Integer" returnTypeFixed="true"/>
          <iteratorExpression xmi:type="expression:Expression" xmi:id="_AzDemoTaskRev01ie" name="multiInstanceIterator" content="multiInstanceIterator" type="MULTIINSTANCE_ITERATOR_TYPE" returnType="java.lang.Object" returnTypeFixed="true"/>
          <completionCondition xmi:type="expression:Expression" xmi:id="_AzDemoTaskRev01cc" name="" content="" returnType="java.lang.Boolean" returnTypeFixed="true"/>
          <formMapping xmi:type="process:FormMapping" xmi:id="_AzDemoTaskRev01fm" type="NONE">
            <targetForm xmi:type="expression:Expression" xmi:id="_AzDemoTaskRev01tf" name="" content="" type="FORM_REFERENCE_TYPE" returnTypeFixed="true"/>
          </formMapping>
          <contract xmi:type="process:Contract" xmi:id="_AzDemoTaskRev01ct"/>
          <expectedDuration xmi:type="expression:Expression" xmi:id="_AzDemoTaskRev01ed" name="" content="" returnType="java.lang.Long" returnTypeFixed="true"/>
        </elements>
        <elements xmi:type="process:EndEvent" xmi:id="_AzDemoEnd01" name="End" incoming="_AzDemoFlow03">
          <dynamicLabel xmi:type="expression:Expression" xmi:id="_AzDemoEnd01dl" name="" content="" returnTypeFixed="true"/>
          <dynamicDescription xmi:type="expression:Expression" xmi:id="_AzDemoEnd01dd" name="" content="" returnTypeFixed="true"/>
          <stepSummary xmi:type="expression:Expression" xmi:id="_AzDemoEnd01ss" name="" content="" returnTypeFixed="true"/>
        </elements>
      </elements>
      <data xmi:type="process:Data" xmi:id="_AzDemoVarAsk01" name="askResult" dataType="_AzDemoStringType">
